rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validations ---

    function isValidCollectionItem(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.description is string && data.description.size() <= 5000 &&
             data.imageUrl is string && data.imageUrl.size() <= 1000 &&
             data.category is string &&
             data.region is string;
    }

    function isValidKingdom(data) {
      return data.name is string && data.name.size() <= 200 &&
             data.description is string && data.description.size() <= 5000 &&
             data.period is string && data.period.size() <= 100;
    }

    function isValidFigure(data) {
      return data.name is string && data.name.size() <= 200 &&
             data.biography is string && data.biography.size() <= 5000 &&
             data.imageUrl is string && data.imageUrl.size() <= 1000;
    }

    function isValidManuscript(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.content is string && data.content.size() <= 10000;
    }

    function isValidExhibition(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.description is string && data.description.size() <= 5000 &&
             data.startDate is timestamp &&
             data.endDate is timestamp;
    }

    // --- Collections ---

    match /admins/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow write: if false; // Only manageable via console for security
    }

    match /collections/{itemId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidCollectionItem(incoming());
      allow delete: if isAdmin();
    }

    match /kingdoms/{kingdomId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidKingdom(incoming());
      allow delete: if isAdmin();
    }

    match /figures/{figureId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidFigure(incoming());
      allow delete: if isAdmin();
    }

    match /manuscripts/{msId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidManuscript(incoming());
      allow delete: if isAdmin();
    }

    match /exhibitions/{exId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidExhibition(incoming());
      allow delete: if isAdmin();
    }

    match /gallery/{itemId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /audio/{trackId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    match /timeline/{eventId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
